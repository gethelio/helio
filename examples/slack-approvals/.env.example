# Slack App credentials — see README.md for setup instructions.
# Copy this file to .env, fill in your values, then run:
#
#   set -a; . ./.env; set +a; pnpm start
#
# All four values are required. helio.yaml references each via
# ${VAR_NAME} interpolation, so secrets stay out of the YAML.

# Bot User OAuth Token — Slack app → OAuth & Permissions → Bot User OAuth Token
HELIO_SLACK_BOT_TOKEN=xoxb-your-bot-token

# Signing Secret — Slack app → Basic Information → App Credentials → Signing Secret
HELIO_SLACK_SIGNING_SECRET=your-signing-secret

# Channel ID for approval messages — right-click channel → View channel details → bottom of panel
HELIO_SLACK_CHANNEL=C0123456789

# Dashboard API secret — generate with: openssl rand -hex 32
# Required when any rule uses require_approval. Used to log into the dashboard
# at http://127.0.0.1:3100 and as a Bearer credential for the sideband API.
HELIO_DASHBOARD_SECRET=replace-with-openssl-rand-hex-32-output
