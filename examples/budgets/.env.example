# Copy to .env and fill in before `pnpm start`:
#   cp .env.example .env

# Dashboard login secret — required because the budget uses
# on_exceed: require_approval. Generate with: openssl rand -hex 32
HELIO_DASHBOARD_SECRET=

# Only needed if you uncomment the Slack channel in helio.yaml.
# See ../slack-approvals/README.md for the Slack app setup.
# HELIO_SLACK_BOT_TOKEN=
# HELIO_SLACK_SIGNING_SECRET=
# HELIO_SLACK_CHANNEL=
