# Copy this file to `.env` and fill in the secret before running
# `docker compose up`. The `.env` file is gitignored.
#
# Generate a secret with:
#
#     openssl rand -hex 32
#
# This secret is the dashboard login secret and can also be used as a
# bearer credential for machine clients. With `dashboard.api_secret` set,
# all dashboard `/api/*` endpoints except `/api/health`,
# `/api/auth/session`, and `/api/auth/logout` require authentication.
# Rotate by editing this value and re-running `docker compose up`.
#
# The value is intentionally empty below — `docker compose up` will
# fail at parse time with a helpful message until you set it. This
# prevents accidentally shipping a placeholder as your shared secret.

HELIO_DASHBOARD_SECRET=
