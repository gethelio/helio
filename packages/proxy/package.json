{
  "name": "@gethelio/proxy",
  "version": "0.0.0",
  "type": "module",
  "description": "Open-source MCP governance proxy for AI agents",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/gethelio/helio.git",
    "directory": "packages/proxy"
  },
  "keywords": [
    "mcp",
    "ai-agents",
    "governance",
    "proxy",
    "audit",
    "policy"
  ],
  "engines": {
    "node": ">=22"
  },
  "files": [
    "dist/"
  ],
  "bin": {
    "helio": "dist/cli.js"
  },
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "dev": "tsup --watch",
    "build:dashboard": "pnpm --filter @gethelio/dashboard build",
    "build:proxy": "tsup",
    "bundle:dashboard-assets": "tsx scripts/bundle-dashboard-assets.ts",
    "check:dashboard-assets": "tsx scripts/check-dashboard-assets.ts",
    "build": "pnpm run build:dashboard && pnpm run build:proxy && pnpm run bundle:dashboard-assets && pnpm run check:dashboard-assets",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "benchmark": "tsx scripts/benchmark.ts",
    "prepack": "pnpm run check:dashboard-assets"
  },
  "devDependencies": {
    "@modelcontextprotocol/sdk": "1.28.0",
    "@types/better-sqlite3": "7.6.13",
    "@types/js-yaml": "4.0.9",
    "@types/node": "25.5.0",
    "@types/picomatch": "4.0.2",
    "tsup": "8.5.1",
    "tsx": "4.21.0",
    "vitest": "4.1.8"
  },
  "dependencies": {
    "@hono/node-server": "2.0.4",
    "@slack/web-api": "7.17.0",
    "better-sqlite3": "12.10.0",
    "chokidar": "5.0.0",
    "commander": "15.0.0",
    "hono": "4.12.25",
    "js-yaml": "4.2.0",
    "picomatch": "4.0.4",
    "safe-regex2": "5.1.1",
    "zod": "4.4.3"
  }
}
